# NextAuth (obrigatório: gere uma secret com openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-key-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# API Backend (usado no cliente para chamadas à API)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Opcional: banco de dados (se usar no futuro)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Opcional: JWT (referência; a autenticação é feita via NextAuth + backend)
# JWT_SECRET=
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_SECRET=
# JWT_REFRESH_EXPIRES_IN=7d
