{
  "name": "nortus-dw-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo Nortus - Frontend Next.js + Backend Node.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @nortus/frontend dev\" \"pnpm --filter @nortus/backend dev\"",
    "dev:frontend": "pnpm --filter @nortus/frontend dev",
    "dev:backend": "pnpm --filter @nortus/backend dev",
    "install:backend": "pnpm --filter @nortus/backend install",
    "build": "pnpm --filter @nortus/frontend build && pnpm --filter @nortus/backend build",
    "build:frontend": "pnpm --filter @nortus/frontend build",
    "build:backend": "pnpm --filter @nortus/backend build",
    "start": "concurrently \"pnpm --filter @nortus/frontend start\" \"pnpm --filter @nortus/backend start\"",
    "lint": "pnpm --filter @nortus/frontend lint",
    "test": "pnpm --filter @nortus/frontend test",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@tanstack/react-query-devtools": "^5.91.3"
  }
}
